# Azure AI Vision Configuration
# Get these values from your Azure Cognitive Services Computer Vision resource

# Azure Computer Vision Multi-Service Endpoint
AZURE_COMPUTER_VISION_ENDPOINT=https://your-resource-name.cognitiveservices.azure.com/

# Azure Computer Vision Multi-Service Key
AZURE_COMPUTER_VISION_KEY=your-32-character-key-here

# Optional: Azure region (automatically detected from endpoint)
AZURE_REGION=eastus

# Processing Configuration
MAX_IMAGE_SIZE_MB=4
PROCESSING_TIMEOUT_SECONDS=30
BATCH_SIZE=5

# Output Configuration
OUTPUT_DIRECTORY=../output
ENABLE_DETAILED_LOGGING=true
SAVE_PROCESSED_IMAGES=false
