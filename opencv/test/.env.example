# LocalStack Environment Configuration
# Copy this file to .env and modify as needed

# LocalStack Configuration
DEBUG=0
PERSISTENCE=1
LOCALSTACK_DOCKER_NAME=localstack-opencv-test
LOCALSTACK_VOLUME_DIR=./volume

# Optional: LocalStack Pro API Key (for advanced features)
# LOCALSTACK_API_KEY=your-api-key-here

# Lambda Configuration
LAMBDA_EXECUTOR=local
LAMBDA_STAY_OPEN_MODE=1

# Test Configuration
TEST_BUCKET_NAME=opencv-test-images
TEST_TABLE_NAME=opencv-test-results
TEST_API_NAME=opencv-test-api

# AWS Configuration for testing
AWS_DEFAULT_REGION=us-west-2
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_ENDPOINT_URL=http://localhost:4566

# Application Configuration
OPENCV_PROFILE=general
TEST_IMAGE_SIZE_LIMIT=104857600  # 100MB
MULTIPART_THRESHOLD=5242880      # 5MB
