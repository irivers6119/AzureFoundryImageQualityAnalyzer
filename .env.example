# =============================================================================
# ENVIRONMENT CONFIGURATION TEMPLATE
# =============================================================================
# Copy this file to .env and replace placeholders with your actual values
# WARNING: Never commit the .env file to version control!

# =============================================================================
# AZURE OPENAI CONFIGURATION (Legacy - for AI-based analyzer)
# =============================================================================
# Azure OpenAI endpoint URL with deployment name and API version
AOAI_ENDPOINT=https://your-resource-name.openai.azure.com/openai/deployments/your-deployment-name/chat/completions?api-version=2024-02-15-preview

# Azure OpenAI API key (32-character string)
AOAI_KEY=your-32-character-azure-openai-api-key-here

# =============================================================================
# AZURE COMPUTER VISION CONFIGURATION (For OCR and Image Analysis)
# =============================================================================
# Azure Computer Vision Multi-Service endpoint
AZURE_COMPUTER_VISION_ENDPOINT=https://your-resource-name.cognitiveservices.azure.com/

# Azure Computer Vision Multi-Service key (32-character string)
AZURE_COMPUTER_VISION_KEY=your-32-character-computer-vision-key-here

# Optional: Azure region (automatically detected from endpoint)
AZURE_REGION=eastus

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
# Maximum image size for processing (in MB)
MAX_IMAGE_SIZE_MB=4

# Processing timeout in seconds
PROCESSING_TIMEOUT_SECONDS=30

# Batch processing size for multiple images
BATCH_SIZE=5

# Output directory for results
OUTPUT_DIRECTORY=./output

# Enable detailed logging (true/false)
ENABLE_DETAILED_LOGGING=true

# =============================================================================
# API SERVICE CONFIGURATION (For containerized API service)
# =============================================================================
# API service host binding
API_HOST=0.0.0.0

# API service port
API_PORT=8000

# Number of worker processes for API service
API_WORKERS=1

# Container mode flag
CONTAINER_MODE=false

# =============================================================================
# SECURITY NOTES
# =============================================================================
# 1. Always use environment variables for sensitive data
# 2. Never commit .env files to version control
# 3. Use least-privilege access for Azure resources
# 4. Rotate keys regularly
# 5. Monitor API usage and set up alerts
# 6. Use Azure Key Vault in production environments
